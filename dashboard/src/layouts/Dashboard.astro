---
import '../styles/global.css';

interface Props {
  title?: string;
  active?: string;
}

const { title = 'Perspective', active = '/' } = Astro.props;

const nav = [
  { href: '/', label: 'Overview' },
  { href: '/processes', label: 'Processes' },
  { href: '/graph', label: 'Graph' },
  { href: '/memories', label: 'Memories' },
  { href: '/config', label: 'Config' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} — Perspective</title>
  </head>
  <body>
    <div class="flex min-h-screen">
      {/* Sidebar */}
      <aside class="w-56 border-r border-zinc-800 flex flex-col">
        <div class="p-5 border-b border-zinc-800">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm">P</div>
            <span class="font-semibold text-lg">Perspective</span>
          </div>
          <div class="text-xs text-zinc-500 mt-1" id="engine-status">connecting...</div>
        </div>
        <nav class="flex-1 p-3 space-y-1">
          {nav.map(item => (
            <a
              href={item.href}
              class={`block px-3 py-2 rounded-lg text-sm transition-colors ${
                active === item.href
                  ? 'bg-zinc-800 text-white'
                  : 'text-zinc-400 hover:text-white hover:bg-zinc-800/50'
              }`}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="p-4 border-t border-zinc-800">
          <div class="text-xs text-zinc-500">Engine</div>
          <div class="flex items-center gap-1.5 mt-1">
            <div class="w-2 h-2 rounded-full bg-green-500" id="health-dot"></div>
            <span class="text-xs text-zinc-400" id="health-text">healthy</span>
          </div>
        </div>
      </aside>

      {/* Main */}
      <main class="flex-1 overflow-auto">
        <div class="p-6">
          <slot />
        </div>
      </main>
    </div>

    <script is:inline>
      const API = window.__PERSPECTIVE_API__ || 'http://localhost:8080';

      async function fetchStatus() {
        try {
          const res = await fetch(`${API}/api/status`);
          if (!res.ok) throw new Error(`${res.status}`);
          const data = await res.json();
          const dot = document.getElementById('health-dot');
          const text = document.getElementById('health-text');
          const status = document.getElementById('engine-status');
          if (dot) dot.className = `w-2 h-2 rounded-full ${data.health === 'healthy' ? 'bg-green-500' : data.health === 'degraded' ? 'bg-yellow-500' : 'bg-red-500'}`;
          if (text) text.textContent = data.health || 'unknown';
          if (status) status.textContent = `${data.total_memories || 0} memories`;
          window.__PERSPECTIVE_DATA__ = data;
        } catch (e) {
          const dot = document.getElementById('health-dot');
          const text = document.getElementById('health-text');
          if (dot) dot.className = 'w-2 h-2 rounded-full bg-red-500';
          if (text) text.textContent = 'offline';
        }
      }
      fetchStatus();
      setInterval(fetchStatus, 5000);
    </script>
  </body>
</html>
