---
import Dashboard from '../layouts/Dashboard.astro';
---

<Dashboard title="Overview" active="/">
  <h1 class="text-2xl font-semibold mb-6">Overview</h1>

  {/* Stats cards */}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-1">Health</div>
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-green-500" id="stat-health-dot"></div>
        <span class="text-2xl font-bold" id="stat-health">Healthy</span>
      </div>
      <div class="text-xs text-zinc-500 mt-1" id="stat-uptime">uptime: --</div>
    </div>
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-1">Total Memories</div>
      <div class="text-2xl font-bold" id="stat-total">0</div>
      <div class="text-xs text-zinc-500 mt-1">across all stores</div>
    </div>
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-1">GC Candidates</div>
      <div class="text-2xl font-bold text-amber-400" id="stat-gc">0</div>
      <div class="text-xs text-zinc-500 mt-1">below decay threshold</div>
    </div>
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-1">Extraction Queue</div>
      <div class="text-2xl font-bold text-blue-400" id="stat-extraction">0</div>
      <div class="text-xs text-zinc-500 mt-1">pending LLM processing</div>
    </div>
  </div>

  {/* Type distribution */}
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-4">Memory Types</div>
      <div class="space-y-3">
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-blue-400">Episodic</span>
            <span id="type-episodic">0</span>
          </div>
          <div class="h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="h-full bg-blue-500 rounded-full transition-all duration-500" id="bar-episodic" style="width:0%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-purple-400">Semantic</span>
            <span id="type-semantic">0</span>
          </div>
          <div class="h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="h-full bg-purple-500 rounded-full transition-all duration-500" id="bar-semantic" style="width:0%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-amber-400">Procedural</span>
            <span id="type-procedural">0</span>
          </div>
          <div class="h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="h-full bg-amber-500 rounded-full transition-all duration-500" id="bar-procedural" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-4">Graph</div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <div class="text-2xl font-bold" id="graph-nodes">0</div>
          <div class="text-xs text-zinc-500">nodes</div>
        </div>
        <div>
          <div class="text-2xl font-bold" id="graph-edges">0</div>
          <div class="text-xs text-zinc-500">edges</div>
        </div>
        <div>
          <div class="text-2xl font-bold" id="graph-communities">0</div>
          <div class="text-xs text-zinc-500">communities</div>
        </div>
        <div>
          <div class="text-2xl font-bold" id="graph-edge-types">0</div>
          <div class="text-xs text-zinc-500">edge types</div>
        </div>
      </div>
    </div>
  </div>

  {/* Activity feed */}
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
    <div class="flex justify-between items-center mb-4">
      <div class="text-sm text-zinc-500">Recent Activity</div>
      <div class="flex gap-2">
        <button class="px-2 py-1 text-xs rounded bg-zinc-800 text-zinc-400 hover:text-white filter-btn active" data-filter="all">all</button>
        <button class="px-2 py-1 text-xs rounded bg-zinc-800 text-zinc-400 hover:text-white filter-btn" data-filter="store">store</button>
        <button class="px-2 py-1 text-xs rounded bg-zinc-800 text-zinc-400 hover:text-white filter-btn" data-filter="recall">recall</button>
        <button class="px-2 py-1 text-xs rounded bg-zinc-800 text-zinc-400 hover:text-white filter-btn" data-filter="reflect">reflect</button>
        <button class="px-2 py-1 text-xs rounded bg-zinc-800 text-zinc-400 hover:text-white filter-btn" data-filter="delete">delete</button>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-zinc-500 text-left border-b border-zinc-800">
            <th class="pb-2 font-medium">Time</th>
            <th class="pb-2 font-medium">Operation</th>
            <th class="pb-2 font-medium">Type</th>
            <th class="pb-2 font-medium">Content</th>
          </tr>
        </thead>
        <tbody id="activity-table">
          <tr><td colspan="4" class="py-4 text-center text-zinc-600">No activity yet</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</Dashboard>

<script is:inline>
  const API = window.__PERSPECTIVE_API__ || 'http://localhost:8080';
  let currentFilter = 'all';

  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.dataset.filter;
      renderActivity(window.__ACTIVITY_DATA__ || []);
    });
  });

  function fmt(n) { return (n || 0).toLocaleString(); }

  function renderStats(data) {
    // Health
    const dot = document.getElementById('stat-health-dot');
    const label = document.getElementById('stat-health');
    if (dot) dot.className = `w-3 h-3 rounded-full ${data.health === 'healthy' ? 'bg-green-500' : data.health === 'degraded' ? 'bg-yellow-500' : 'bg-red-500'}`;
    if (label) label.textContent = (data.health || 'unknown').charAt(0).toUpperCase() + (data.health || 'unknown').slice(1);

    // Uptime
    const uptime = document.getElementById('stat-uptime');
    if (uptime && data.uptime_secs != null) {
      const h = Math.floor(data.uptime_secs / 3600);
      const m = Math.floor((data.uptime_secs % 3600) / 60);
      uptime.textContent = `uptime: ${h}h ${m}m`;
    }

    // Totals
    document.getElementById('stat-total').textContent = fmt(data.total_memories);
    document.getElementById('stat-gc').textContent = fmt(data.gc_candidates);
    document.getElementById('stat-extraction').textContent = fmt(data.extraction_queue || 0);

    // Types
    const types = data.memory_types || {};
    const ep = types.episodic || 0;
    const sem = types.semantic || 0;
    const proc = types.procedural || 0;
    const total = ep + sem + proc || 1;
    document.getElementById('type-episodic').textContent = fmt(ep);
    document.getElementById('type-semantic').textContent = fmt(sem);
    document.getElementById('type-procedural').textContent = fmt(proc);
    document.getElementById('bar-episodic').style.width = (ep / total * 100) + '%';
    document.getElementById('bar-semantic').style.width = (sem / total * 100) + '%';
    document.getElementById('bar-procedural').style.width = (proc / total * 100) + '%';

    // Graph
    const graph = data.graph || {};
    document.getElementById('graph-nodes').textContent = fmt(graph.nodes);
    document.getElementById('graph-edges').textContent = fmt(graph.edges);
    document.getElementById('graph-communities').textContent = fmt(graph.communities);
    document.getElementById('graph-edge-types').textContent = fmt(graph.edge_types);
  }

  function renderActivity(events) {
    window.__ACTIVITY_DATA__ = events;
    const tbody = document.getElementById('activity-table');
    const filtered = currentFilter === 'all' ? events : events.filter(e => e.operation === currentFilter);

    if (!filtered || filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="4" class="py-4 text-center text-zinc-600">No activity yet</td></tr>';
      return;
    }

    tbody.innerHTML = filtered.map(e => {
      const time = e.timestamp ? new Date(e.timestamp).toLocaleTimeString() : '--';
      const opColor = { store: 'text-green-400', recall: 'text-blue-400', reflect: 'text-purple-400', delete: 'text-red-400' }[e.operation] || 'text-zinc-400';
      const typeColor = { episodic: 'text-blue-400', semantic: 'text-purple-400', procedural: 'text-amber-400' }[e.memory_type] || 'text-zinc-400';
      const content = (e.content || '').substring(0, 80);
      return `<tr class="border-b border-zinc-800/50">
        <td class="py-2 text-zinc-500">${time}</td>
        <td class="py-2 ${opColor}">${e.operation || '--'}</td>
        <td class="py-2 ${typeColor}">${e.memory_type || '--'}</td>
        <td class="py-2 text-zinc-300">${content}${content.length >= 80 ? '...' : ''}</td>
      </tr>`;
    }).join('');
  }

  async function refresh() {
    try {
      const [statusRes, activityRes] = await Promise.all([
        fetch(`${API}/api/status`),
        fetch(`${API}/api/activity?limit=50`)
      ]);
      if (statusRes.ok) renderStats(await statusRes.json());
      if (activityRes.ok) renderActivity((await activityRes.json()).events || []);
    } catch (e) {}
  }

  refresh();
  setInterval(refresh, 5000);
</script>

<style>
  .filter-btn.active {
    background: #27272a;
    color: #fafafa;
  }
</style>
