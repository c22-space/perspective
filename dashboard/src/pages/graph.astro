---
import Dashboard from '../layouts/Dashboard.astro';
---

<Dashboard title="Graph" active="/graph">
  <h1 class="text-2xl font-semibold mb-6">Knowledge Graph</h1>

  {/* Stats */}
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-1">Total Nodes</div>
      <div class="text-2xl font-bold" id="g-nodes">0</div>
    </div>
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-1">Total Edges</div>
      <div class="text-2xl font-bold" id="g-edges">0</div>
    </div>
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-1">Communities</div>
      <div class="text-2xl font-bold" id="g-communities">0</div>
    </div>
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-1">Avg Connectivity</div>
      <div class="text-2xl font-bold" id="g-connectivity">0.0</div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    {/* Node Types */}
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-4">Node Types</div>
      <div class="space-y-3">
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-blue-400">Memory Ref</span>
            <span id="node-memory">0</span>
          </div>
          <div class="h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="h-full bg-blue-500 rounded-full transition-all duration-500" id="bar-node-memory" style="width:0%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-green-400">Entity</span>
            <span id="node-entity">0</span>
          </div>
          <div class="h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="h-full bg-green-500 rounded-full transition-all duration-500" id="bar-node-entity" style="width:0%"></div>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-purple-400">Concept</span>
            <span id="node-concept">0</span>
          </div>
          <div class="h-2 bg-zinc-800 rounded-full overflow-hidden">
            <div class="h-full bg-purple-500 rounded-full transition-all duration-500" id="bar-node-concept" style="width:0%"></div>
          </div>
        </div>
      </div>
    </div>

    {/* Edge Types */}
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="text-sm text-zinc-500 mb-4">Edge Types</div>
      <div class="space-y-2" id="edge-type-list">
        <div class="text-sm text-zinc-600">Loading...</div>
      </div>
    </div>
  </div>

  {/* Recent Edges */}
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
    <div class="text-sm text-zinc-500 mb-4">Recent Edges</div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-zinc-500 text-left border-b border-zinc-800">
            <th class="pb-2 font-medium">Created</th>
            <th class="pb-2 font-medium">Type</th>
            <th class="pb-2 font-medium">From</th>
            <th class="pb-2 font-medium">To</th>
            <th class="pb-2 font-medium">Weight</th>
          </tr>
        </thead>
        <tbody id="edge-table">
          <tr><td colspan="5" class="py-4 text-center text-zinc-600">No edges yet</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</Dashboard>

<script is:inline>
  const API = window.__PERSPECTIVE_API__ || 'http://localhost:8080';
  const EDGE_COLORS = {
    temporal: 'text-blue-400', semantic: 'text-purple-400', entity: 'text-green-400',
    causal: 'text-red-400', hierarchical: 'text-amber-400', associative: 'text-cyan-400',
    co_occurrence: 'text-pink-400', reinforcement: 'text-orange-400'
  };

  function fmt(n) { return (n || 0).toLocaleString(); }

  function renderGraphStats(data) {
    const g = data.graph || {};
    document.getElementById('g-nodes').textContent = fmt(g.total_nodes);
    document.getElementById('g-edges').textContent = fmt(g.total_edges);
    document.getElementById('g-communities').textContent = fmt(g.communities);
    document.getElementById('g-connectivity').textContent = (g.avg_connectivity || 0).toFixed(2);

    // Node types
    const nodes = g.node_types || {};
    const nm = nodes.memory_ref || 0;
    const ne = nodes.entity || 0;
    const nc = nodes.concept || 0;
    const nt = nm + ne + nc || 1;
    document.getElementById('node-memory').textContent = fmt(nm);
    document.getElementById('node-entity').textContent = fmt(ne);
    document.getElementById('node-concept').textContent = fmt(nc);
    document.getElementById('bar-node-memory').style.width = (nm / nt * 100) + '%';
    document.getElementById('bar-node-entity').style.width = (ne / nt * 100) + '%';
    document.getElementById('bar-node-concept').style.width = (nc / nt * 100) + '%';

    // Edge types
    const edges = g.edge_types || {};
    const edgeList = document.getElementById('edge-type-list');
    const edgeEntries = Object.entries(edges).sort((a, b) => b[1] - a[1]);
    if (edgeEntries.length === 0) {
      edgeList.innerHTML = '<div class="text-sm text-zinc-600">No edges</div>';
    } else {
      edgeList.innerHTML = edgeEntries.map(([type, count]) => {
        const color = EDGE_COLORS[type] || 'text-zinc-400';
        return `<div class="flex justify-between text-sm py-1">
          <span class="${color}">${type}</span>
          <span>${fmt(count)}</span>
        </div>`;
      }).join('');
    }

    // Recent edges
    const recent = g.recent_edges || [];
    const tbody = document.getElementById('edge-table');
    if (!recent.length) {
      tbody.innerHTML = '<tr><td colspan="5" class="py-4 text-center text-zinc-600">No edges yet</td></tr>';
    } else {
      tbody.innerHTML = recent.map(e => {
        const color = EDGE_COLORS[e.edge_type] || 'text-zinc-400';
        return `<tr class="border-b border-zinc-800/50">
          <td class="py-2 text-zinc-500">${e.created_at ? new Date(e.created_at).toLocaleString() : '--'}</td>
          <td class="py-2 ${color}">${e.edge_type || '--'}</td>
          <td class="py-2 text-zinc-400 font-mono text-xs">${(e.from_id || '').substring(0, 8)}</td>
          <td class="py-2 text-zinc-400 font-mono text-xs">${(e.to_id || '').substring(0, 8)}</td>
          <td class="py-2 text-zinc-400">${e.weight != null ? e.weight.toFixed(2) : '--'}</td>
        </tr>`;
      }).join('');
    }
  }

  async function refresh() {
    try {
      const res = await fetch(`${API}/api/graph`);
      if (!res.ok) throw new Error(`${res.status}`);
      renderGraphStats(await res.json());
    } catch (e) {}
  }

  refresh();
  setInterval(refresh, 5000);
</script>
