---
import Dashboard from '../layouts/Dashboard.astro';
---

<Dashboard title="Processes" active="/processes">
  <h1 class="text-2xl font-semibold mb-6">Background Processes</h1>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    {/* Consolidation */}
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <div class="text-sm text-zinc-500">Consolidation</div>
        <div class="flex items-center gap-1.5">
          <div class="w-2 h-2 rounded-full bg-green-500" id="cons-status-dot"></div>
          <span class="text-xs text-zinc-400" id="cons-status">idle</span>
        </div>
      </div>
      <div class="space-y-3">
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">Last Run</span>
          <span class="text-sm" id="cons-last-run">--</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">Next Run</span>
          <span class="text-sm" id="cons-next-run">--</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">Items Processed</span>
          <span class="text-sm" id="cons-processed">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">Merges Performed</span>
          <span class="text-sm" id="cons-merges">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">Promotions (episodic→semantic)</span>
          <span class="text-sm" id="cons-promotions">0</span>
        </div>
      </div>
    </div>

    {/* Decay */}
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <div class="text-sm text-zinc-500">Decay System</div>
        <div class="flex items-center gap-1.5">
          <div class="w-2 h-2 rounded-full bg-green-500" id="decay-status-dot"></div>
          <span class="text-xs text-zinc-400" id="decay-status">active</span>
        </div>
      </div>
      <div class="space-y-3">
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">GC Candidates</span>
          <span class="text-sm text-amber-400" id="decay-gc">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">Last GC Run</span>
          <span class="text-sm" id="decay-last-gc">--</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">Items Collected</span>
          <span class="text-sm" id="decay-collected">0</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">Avg Stability (episodic)</span>
          <span class="text-sm" id="decay-stability-ep">--</span>
        </div>
        <div class="flex justify-between">
          <span class="text-sm text-zinc-400">Avg Stability (semantic)</span>
          <span class="text-sm" id="decay-stability-sem">--</span>
        </div>
      </div>
    </div>
  </div>

  {/* Extraction Queue */}
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 mb-6">
    <div class="flex items-center justify-between mb-4">
      <div class="text-sm text-zinc-500">Extraction Queue (LLM)</div>
      <span class="text-xs text-zinc-400" id="extract-count">0 pending</span>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-zinc-500 text-left border-b border-zinc-800">
            <th class="pb-2 font-medium">Enqueued</th>
            <th class="pb-2 font-medium">Source</th>
            <th class="pb-2 font-medium">Content Preview</th>
            <th class="pb-2 font-medium">Status</th>
          </tr>
        </thead>
        <tbody id="extract-table">
          <tr><td colspan="4" class="py-4 text-center text-zinc-600">Queue empty</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  {/* Consolidation History */}
  <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
    <div class="text-sm text-zinc-500 mb-4">Consolidation History</div>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-zinc-500 text-left border-b border-zinc-800">
            <th class="pb-2 font-medium">Time</th>
            <th class="pb-2 font-medium">Duration</th>
            <th class="pb-2 font-medium">Memories Processed</th>
            <th class="pb-2 font-medium">Merges</th>
            <th class="pb-2 font-medium">Promotions</th>
            <th class="pb-2 font-medium">GC Collected</th>
          </tr>
        </thead>
        <tbody id="cons-history">
          <tr><td colspan="6" class="py-4 text-center text-zinc-600">No consolidation runs yet</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</Dashboard>

<script is:inline>
  const API = window.__PERSPECTIVE_API__ || 'http://localhost:8080';

  function fmt(n) { return (n || 0).toLocaleString(); }
  function fmtTime(ts) {
    if (!ts) return '--';
    return new Date(ts).toLocaleString();
  }
  function fmtDuration(ms) {
    if (!ms) return '--';
    if (ms < 1000) return `${ms}ms`;
    return `${(ms / 1000).toFixed(1)}s`;
  }

  function renderConsolidation(data) {
    const c = data.consolidation || {};
    const dot = document.getElementById('cons-status-dot');
    const status = document.getElementById('cons-status');
    if (dot) dot.className = `w-2 h-2 rounded-full ${c.running ? 'bg-blue-500 animate-pulse' : 'bg-green-500'}`;
    if (status) status.textContent = c.running ? 'running' : 'idle';
    document.getElementById('cons-last-run').textContent = fmtTime(c.last_run);
    document.getElementById('cons-next-run').textContent = fmtTime(c.next_run);
    document.getElementById('cons-processed').textContent = fmt(c.items_processed);
    document.getElementById('cons-merges').textContent = fmt(c.merges);
    document.getElementById('cons-promotions').textContent = fmt(c.promotions);
  }

  function renderDecay(data) {
    const d = data.decay || {};
    document.getElementById('decay-gc').textContent = fmt(d.gc_candidates);
    document.getElementById('decay-last-gc').textContent = fmtTime(d.last_gc_run);
    document.getElementById('decay-collected').textContent = fmt(d.items_collected);
    document.getElementById('decay-stability-ep').textContent = d.avg_stability_episodic != null ? d.avg_stability_episodic.toFixed(2) : '--';
    document.getElementById('decay-stability-sem').textContent = d.avg_stability_semantic != null ? d.avg_stability_semantic.toFixed(2) : '--';
  }

  function renderExtraction(data) {
    const q = data.extraction_queue || [];
    document.getElementById('extract-count').textContent = `${q.length} pending`;
    const tbody = document.getElementById('extract-table');
    if (!q.length) {
      tbody.innerHTML = '<tr><td colspan="4" class="py-4 text-center text-zinc-600">Queue empty</td></tr>';
      return;
    }
    tbody.innerHTML = q.map(e => {
      const statusColor = { pending: 'text-zinc-400', processing: 'text-blue-400', failed: 'text-red-400' }[e.status] || 'text-zinc-400';
      return `<tr class="border-b border-zinc-800/50">
        <td class="py-2 text-zinc-500">${fmtTime(e.enqueued_at)}</td>
        <td class="py-2 text-zinc-400">${e.source || '--'}</td>
        <td class="py-2 text-zinc-300">${(e.preview || '').substring(0, 60)}</td>
        <td class="py-2 ${statusColor}">${e.status || '--'}</td>
      </tr>`;
    }).join('');
  }

  function renderHistory(data) {
    const runs = data.consolidation_history || [];
    const tbody = document.getElementById('cons-history');
    if (!runs.length) {
      tbody.innerHTML = '<tr><td colspan="6" class="py-4 text-center text-zinc-600">No consolidation runs yet</td></tr>';
      return;
    }
    tbody.innerHTML = runs.map(r => `<tr class="border-b border-zinc-800/50">
      <td class="py-2 text-zinc-500">${fmtTime(r.time)}</td>
      <td class="py-2 text-zinc-400">${fmtDuration(r.duration_ms)}</td>
      <td class="py-2 text-zinc-400">${fmt(r.memories_processed)}</td>
      <td class="py-2 text-zinc-400">${fmt(r.merges)}</td>
      <td class="py-2 text-purple-400">${fmt(r.promotions)}</td>
      <td class="py-2 text-amber-400">${fmt(r.gc_collected)}</td>
    </tr>`).join('');
  }

  async function refresh() {
    try {
      const res = await fetch(`${API}/api/processes`);
      if (!res.ok) throw new Error(`${res.status}`);
      const data = await res.json();
      renderConsolidation(data);
      renderDecay(data);
      renderExtraction(data);
      renderHistory(data);
    } catch (e) {}
  }

  refresh();
  setInterval(refresh, 5000);
</script>
